# Entorno de aplicación
APP_ENV=production
APP_URL=http://localhost/BetMatch

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=betmatch_db
DB_USERNAME=root
DB_PASSWORD=

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_RETURN_URL=http://localhost/BetMatch/public/paypal-execute.php
PAYPAL_CANCEL_URL=http://localhost/BetMatch/public/perfil.php
